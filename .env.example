VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
# Clerk secret key (server-only, never expose to client)
CLERK_SECRET_KEY=

# Supabase (client + server)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Supabase service role (server-only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI for AI trail finder + AI build generator (server-only)
OPENAI_API_KEY=

# Newsletter signup recipient (default fallback in /api/subscribe)
RECIPIENT_EMAIL=

# Lemon Squeezy — Wilder Builds subscription (merchant of record)
# Two variants on one product: monthly + annual.
LEMON_API_KEY=
LEMON_WEBHOOK_SECRET=
LEMON_STORE_ID=
LEMON_VARIANT_ID_MONTHLY=
LEMON_VARIANT_ID_ANNUAL=
LEMON_CHECKOUT_SUCCESS_URL=https://your-domain.com/wilder-builds?subscribed=1
LEMON_CHECKOUT_CANCEL_URL=https://your-domain.com/wilder-builds

# Resend — for both transactional emails and the monthly broadcast audience
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
RESEND_FROM_ADDRESS=Wilder Moms <hello@wildermoms.com>

# Vercel cron protection — required header value to invoke /api/cron/*
CRON_SECRET=

# Supabase service role (server-only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: PostHog analytics for subscription funnel events
VITE_POSTHOG_KEY=
